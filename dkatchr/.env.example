# dKatchr CLI environment variables
# Copy to .env in the project root and fill in your values:
#   cp dkatchr/.env.example .env

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

GITHUB_TOKEN=ghp_your_personal_access_token_here

# ---------------------------------------------------------------------------
# Rate limits
# ---------------------------------------------------------------------------

# DKATCHR_GITHUB_RPS=1.3       # sustained req/s against GitHub API (auth budget: 5000/hr)
# DKATCHR_GITHUB_BURST=5       # burst allowance on top of sustained rate
# DKATCHR_OSV_RPS=5            # sustained req/s against OSV.dev
# DKATCHR_OSV_BURST=10

# ---------------------------------------------------------------------------
# Cache / TTLs
# ---------------------------------------------------------------------------

# DKATCHR_OSV_TTL=86400        # seconds to cache OSV vuln lookups (default: 24h)
# DKATCHR_KEV_TTL=86400        # seconds to cache CISA KEV catalog (default: 24h)

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------

# DKATCHR_WORKERS=8                      # OSV detail-fetch concurrency
# DKATCHR_REGISTRY_RESOLVER_WORKERS=6   # import-name resolver concurrency (reachability)

# ---------------------------------------------------------------------------
# Reachability
# ---------------------------------------------------------------------------

# DKATCHR_REACHABILITY_TARBALL_MAX_BYTES=5368709120   # safety cap on streamed tarballs (default: 5GB)
